          "name": "get-animal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Response has all required fields\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    pm.expect(json).to.have.property(\"id\");\r",
                  "    pm.expect(json).to.have.property(\"address\");\r",
                  "    pm.expect(json).to.have.property(\"type\");\r",
                  "    pm.expect(json).to.have.property(\"animalStatus\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check animal status\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.animalStatus).to.equal(\"NOT_UNDER_PATRONAGE\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Field types are correct\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    pm.expect(json.id).to.be.a(\"number\");\r",
                  "    pm.expect(json.address).to.be.a(\"string\");\r",
                  "    pm.expect(json.type).to.be.a(\"string\");\r",
                  "    pm.expect(json.animalStatus).to.be.a(\"string\");\r",
                  "});"
