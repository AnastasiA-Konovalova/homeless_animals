              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content is array\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.content).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each animal has required fields\", function() {\r",
                  "        const json = pm.response.json();\r",
                  "\r",
                  "        if (json.content.length > 0) {\r",
                  "            const animal = json.content[0];\r",
                  "        \r",
                  "            pm.expect(animal).to.have.property(\"id\");\r",
                  "            pm.expect(animal).to.have.property(\"type\");\r",
                  "            pm.expect(animal).to.have.property(\"address\");\r",
                  "            pm.expect(animal).to.have.property(\"animalStatus\");\r",
                  "            pm.expect(animal).to.have.property(\"volunteer\");\r",
                  "        }\r",
                  "    });\r",
                  "\r",
                  "pm.test(\"Pagination values are correct\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    pm.expect(json.number).to.eql(0);\r",
                  "    pm.expect(json.size).to.eql(20);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Sorted by id ascending\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    if (json.content.length > 1) {\r",
                  "        pm.expect(json.content[0].id).to.be.below(json.content[1].id);\r",
                  "}\r",
                  "});\r",
                  ""
